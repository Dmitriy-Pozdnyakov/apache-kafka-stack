# Образы контейнеров
KAFKA_IMAGE=apache/kafka:4.2.0
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:v0.7.2
KAFKA_EXPORTER_IMAGE=danielqsj/kafka-exporter:v1.8.0
SCHEMA_REGISTRY_IMAGE=confluentinc/cp-schema-registry:7.7.1
VICTORIAMETRICS_IMAGE=victoriametrics/victoria-metrics:v1.117.1
VMAGENT_IMAGE=victoriametrics/vmagent:v1.117.1
GRAFANA_IMAGE=grafana/grafana:11.1.4
NGINX_IMAGE=nginx:1.27-alpine

# KRaft
# CLUSTER_ID: уникальный идентификатор кластера Kafka KRaft
CLUSTER_ID=z5pCn8FUTnWgoBKNBWEBMA
# KAFKA_CONTROLLER_QUORUM_VOTERS: список контроллеров KRaft
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka-1:9093,2@kafka-2:9093,3@kafka-3:9093

# Топики Kafka и настройки консюмера
# BROKER: список bootstrap-серверов для сервисов/скриптов
BROKER=kafka-1:9092,kafka-2:9092,kafka-3:9092
# BOOTSTRAP_BROKER: single bootstrap для admin-скриптов (kafka-init)
BOOTSTRAP_BROKER=kafka-1:9092
# TOPIC: основной топик
TOPIC=transactions
# RETRY_TOPIC: топик для отложенной повторной обработки
RETRY_TOPIC=transactions.retry
# DLQ_TOPIC: dead-letter топик для неуспешных сообщений
DLQ_TOPIC=transactions.dlq
# GROUP_ID: id consumer group для воркеров
GROUP_ID=transactions-workers
# TOPIC_PARTITIONS: целевое число partition для создаваемых топиков
TOPIC_PARTITIONS=3
# TOPIC_REPLICATION_FACTOR: replication factor для создаваемых топиков
TOPIC_REPLICATION_FACTOR=3

# Кластерные требования Kafka (3 ноды)
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=3
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=3
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=2
KAFKA_MIN_INSYNC_REPLICAS=2

# Политики хранения топиков (retention/cleanup)
# KAFKA_INIT_WAIT_TIMEOUT_SEC: timeout ожидания Kafka в init-скрипте (сек)
KAFKA_INIT_WAIT_TIMEOUT_SEC=240
# KAFKA_CONFIG_APPLY_TIMEOUT_SEC: timeout применения topic config через kafka-configs.sh
KAFKA_CONFIG_APPLY_TIMEOUT_SEC=30
# TOPIC_RETENTION_MS: хранение основного топика (7 дней)
TOPIC_RETENTION_MS=604800000
# TOPIC_CLEANUP_POLICY: delete или compact
TOPIC_CLEANUP_POLICY=delete
# RETRY_TOPIC_RETENTION_MS: хранение retry-топика (1 день)
RETRY_TOPIC_RETENTION_MS=86400000
# RETRY_TOPIC_CLEANUP_POLICY: delete или compact
RETRY_TOPIC_CLEANUP_POLICY=delete
# DLQ_TOPIC_RETENTION_MS: хранение DLQ-топика (14 дней)
DLQ_TOPIC_RETENTION_MS=1209600000
# DLQ_TOPIC_CLEANUP_POLICY: delete или compact
DLQ_TOPIC_CLEANUP_POLICY=delete

# Порты на хосте
# PUBLIC_HOST: IPv4 адрес хоста/ВМ для EXTERNAL advertised.listeners Kafka (режим без DNS)
PUBLIC_HOST=127.0.0.1
KAFKA_1_PORT=19092
KAFKA_2_PORT=19093
KAFKA_3_PORT=19094
KAFKA_UI_PORT=18085
KAFKA_EXPORTER_PORT=19308
SCHEMA_REGISTRY_PORT=18081
VICTORIAMETRICS_PORT=18428
GRAFANA_PORT=13000
NGINX_PORT=18080

# JVM heap
# KAFKA_HEAP_OPTS: heap для брокера Kafka
KAFKA_HEAP_OPTS=-Xms512m -Xmx1024m
# TLS для EXTERNAL listener Kafka
# KAFKA_EXTERNAL_SECURITY_PROTOCOL: SASL_SSL (рекомендуется), SSL или PLAINTEXT
KAFKA_EXTERNAL_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SSL_KEYSTORE_PASSWORD=changeit
KAFKA_SSL_KEY_PASSWORD=changeit
KAFKA_SSL_TRUSTSTORE_PASSWORD=changeit
# KAFKA_SSL_CLIENT_AUTH: none|requested|required
KAFKA_SSL_CLIENT_AUTH=none
# Логин/пароль Kafka для внешних клиентов (SASL/PLAIN на EXTERNAL listener)
KAFKA_SASL_USERNAME=kafka_user
KAFKA_SASL_PASSWORD=change_me_kafka_password
# KAFKA_UI_JAVA_OPTS: heap для Kafka UI
KAFKA_UI_JAVA_OPTS=-Xms128m -Xmx256m
# KAFKA_UI_AUTH_TYPE: тип аутентификации Kafka UI (LOGIN_FORM для логина)
KAFKA_UI_AUTH_TYPE=LOGIN_FORM
# KAFKA_UI_USER/KAFKA_UI_PASSWORD: учетные данные Kafka UI
KAFKA_UI_USER=change_me_ui_user
KAFKA_UI_PASSWORD=change_me_ui_password

# Лимиты ресурсов контейнеров
KAFKA_MEM_LIMIT=2g
KAFKA_CPUS=1.50
KAFKA_INIT_MEM_LIMIT=256m
KAFKA_INIT_CPUS=0.25
WORKER_MEM_LIMIT=512m
WORKER_CPUS=0.50
KAFKA_UI_MEM_LIMIT=512m
KAFKA_UI_CPUS=0.50
KAFKA_EXPORTER_MEM_LIMIT=256m
KAFKA_EXPORTER_CPUS=0.25
SCHEMA_REGISTRY_MEM_LIMIT=512m
SCHEMA_REGISTRY_CPUS=0.50
VICTORIAMETRICS_MEM_LIMIT=512m
VICTORIAMETRICS_CPUS=0.50
VMAGENT_MEM_LIMIT=256m
VMAGENT_CPUS=0.25
GRAFANA_MEM_LIMIT=512m
GRAFANA_CPUS=0.50
NGINX_MEM_LIMIT=128m
NGINX_CPUS=0.25

# Grafana
# GRAFANA_ADMIN_USER/GRAFANA_ADMIN_PASSWORD: учетные данные веб-интерфейса Grafana
GRAFANA_ADMIN_USER=change_me_grafana_user
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
# GRAFANA_ANONYMOUS_ENABLED/GRAFANA_DISABLE_LOGIN_FORM: при false/false будет обычная форма логина
GRAFANA_ANONYMOUS_ENABLED=false
GRAFANA_ANONYMOUS_ORG_ROLE=Viewer
GRAFANA_DISABLE_LOGIN_FORM=false
GRAFANA_USERS_ALLOW_SIGN_UP=false
# GRAFANA_HOME_DASHBOARD_PATH: стартовый dashboard при входе в Grafana
GRAFANA_HOME_DASHBOARD_PATH=/var/lib/grafana/dashboards/kafka-overview.json

# VictoriaMetrics
# VICTORIAMETRICS_RETENTION: срок хранения метрик (например 30d, 90d, 12)
VICTORIAMETRICS_RETENTION=30d

# Параметры IPAM для docker-сети (apache_shared_net)
APACHE_SHARED_NET_SUBNET=172.31.0.0/24
APACHE_SHARED_NET_GATEWAY=172.31.0.1
